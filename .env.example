# Assistant / n8n integration
# Leave N8N_WEBHOOK_URL empty to use the local FAQ fallback.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_CHAT_PATH=chat

# Telegram bot (only needed for Telegram channel)
TELEGRAM_BOT_TOKEN=

# Optional: public URL of this app, used by the n8n workflow to call /api/resolve
LUMIA_API_URL=http://localhost:3000
